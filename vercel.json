{
  "version": 2,
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "src/server/data/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index?_url=/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "/public/uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
